# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/crm_omnicomm?connection_limit=5&pool_timeout=10

# --- Auth ---
JWT_SECRET=change-me-32-bytes-min

# --- Omnicomm integration ---
OMNICOMM_API_URL=https://online.omnicomm.ru
OMNICOMM_LOGIN=
OMNICOMM_PASSWORD=
# интервал инкрементального синка, часы
OMNICOMM_SYNC_INTERVAL_HOURS=3
